Import('env')
import os, inspect

#-------------------------------------------------------------------------------
# Adds self
#-------------------------------------------------------------------------------
if "SNS_ISLAND_INCLUDE_DA_TEST" in env:
  da_test_island_cfg = True
else:
  da_test_island_cfg = False

#-------------------------------------------------------------------------------
# Non island symbols to whitelist
# Add all the non island symbols used in island sections
# Verify that the symbol is used only after exiting island before adding
# to this list
#-------------------------------------------------------------------------------

SYMBOLS_TO_WHITELIST = [
'sns_da_test_deinit',
'sns_da_test_inst_deinit',
'sns_da_test_inst_init',
'sns_da_test_init',
'sns_da_test_notify_event',
'sns_da_test_set_client_request',
'sns_da_test_inst_handle_flush_timer_event',
'sns_da_test_inst_handle_stop_n_go_timer_event',
'sns_da_test_inst_handle_suid_event',
'sns_da_test_inst_handle_timer_event',
'sns_da_test_inst_send_suid_req',
'sns_da_test_inst_sensor_process_event',
'sns_da_test_inst_start_sensor_stream',
'start_da_test_inst_procedure',
'parse_input'
]

if 'USES_SSC_STATIC_LIB_BUILDER' in env:
  env.AddSSCSU(inspect.getfile(inspect.currentframe()),
               clean_pack_list = ['*.c','*.h'],
               cflags = ['-Wno-sign-compare'],
               register_func_name = "sns_da_test_register",
               binary_lib = True,
               add_island_files = da_test_island_cfg,
               diag_ssid = "MSG_SSID_SNS_SENSOR_EXT",
               symbols_to_whitelist = SYMBOLS_TO_WHITELIST)
